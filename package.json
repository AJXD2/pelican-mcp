{
  "name": "pelican-mcp",
  "version": "1.0.1",
  "description": "MCP server for managing Pelican Panel game servers",
  "module": "index.ts",
  "main": "dist/index.js",
  "bin": {
    "pelican-mcp": "dist/index.js"
  },
  "type": "module",
  "files": [
    "dist/"
  ],
  "scripts": {
    "start": "bun run src/index.ts",
    "build": "bun build src/index.ts --target=node --outfile=dist/index.js && node -e \"const fs=require('fs');const f='dist/index.js';fs.writeFileSync(f,'#!/usr/bin/env node\\n'+fs.readFileSync(f,'utf8'))\"",
    "prepublishOnly": "bun run build"
  },
  "keywords": ["mcp", "pelican", "game-server", "pterodactyl", "claude"],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/AJXD2/pelican-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/AJXD2/pelican-mcp/issues"
  },
  "homepage": "https://github.com/AJXD2/pelican-mcp#readme",
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "zod": "^4.3.6"
  }
}
